<Window x:Class="MAB_Mailer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MAB_Mailer"
        Title="MAB TECH MAILER" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" 
        AllowsTransparency="True" 
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="WatermarkTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="6">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="watermark" Text="{TemplateBinding Tag}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       Foreground="{DynamicResource TextSecondary}"
                                       IsHitTestVisible="False"
                                       Opacity="0.6"
                                       FontStyle="Italic"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#29B6F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Border Background="{DynamicResource CardBackground}" CornerRadius="15">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="20" ShadowDepth="5" Opacity="0.4"/>
            </Border.Effect>
        </Border>

        <Border Background="{DynamicResource AppBackground}" CornerRadius="15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="160"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource CardBackground}" MouseDown="TitleBar_MouseDown" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" CornerRadius="15,15,15,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                            <Border Background="#0288D1" Width="8" Height="25" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="MAB TECH" FontWeight="Black" FontSize="18" Foreground="#0277BD" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="Logo_Click"/>
                            <TextBlock Text=" | MAILER" FontWeight="Regular" FontSize="18" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Content="—" Width="45" Height="30" Style="{DynamicResource TitleBarButtonStyle}" Click="BtnMinimize_Click"/>
                            <Button x:Name="btnMaximize" Content="☐" Width="45" Height="30" Style="{DynamicResource TitleBarButtonStyle}" Click="BtnMaximize_Click"/>
                            <Button Content="✕" Width="45" Height="30" Style="{DynamicResource CloseButtonStyle}" Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="15,15,15,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="10" Margin="0,0,10,0" Padding="10" BorderThickness="0">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="5" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Kişi Yönetimi" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>

                                <UniformGrid Columns="2" Margin="0,0,0,10">
                                    <Button Content="Excel Şablonu" Click="BtnTemplate_Click" Style="{DynamicResource BaseGlassButton}" Margin="2"/>
                                    <Button Content="Yükle / Güncelle" Click="BtnImport_Click" Style="{DynamicResource GreenGlassButton}" Margin="2"/>
                                </UniformGrid>

                                <Separator Background="{DynamicResource BorderBrush}" Margin="0,5"/>

                                <TextBlock Text="Hızlı Kişi Ekle:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtNewName" Grid.Column="0" Margin="0,0,2,5" Height="30" Padding="5" 
                                             Style="{StaticResource WatermarkTextBox}" Tag="Ad"/>
                                    <TextBox x:Name="txtNewSurname" Grid.Column="1" Margin="2,0,0,5" Height="30" Padding="5" 
                                             Style="{StaticResource WatermarkTextBox}" Tag="Soyad"/>
                                </Grid>

                                <TextBox x:Name="txtNewMail" Margin="0,0,0,5" Height="30" Padding="5" 
                                         Style="{StaticResource WatermarkTextBox}" Tag="E-Posta (ornek@mail.com)"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="txtNewGroup" Grid.Column="0" Margin="0,0,5,0" Height="30" Padding="5" 
                                             Style="{StaticResource WatermarkTextBox}" Tag="Grup (Örn: IT Ekip)"/>

                                    <Button x:Name="btnCancelEdit" Grid.Column="1" Content="X" Width="30" Height="28" Margin="0,0,5,0" 
                                            Click="BtnCancelEdit_Click" Style="{DynamicResource RedGlassButton}" 
                                            ToolTip="Düzenlemeyi İptal Et" Visibility="Collapsed"/>

                                    <Button x:Name="btnAddOrUpdate" Content="EKLE" Grid.Column="2" Width="70" Height="28" 
                                            Click="BtnAddPerson_Click" Style="{DynamicResource GreenGlassButton}"/>
                                </Grid>

                                <Separator Background="{DynamicResource BorderBrush}" Margin="0,5"/>

                                <TextBlock Text="Grup Filtrele / Sil" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton x:Name="btnGroupMenu" Content="Gruplar (Seç)" Height="30" Margin="0,0,2,0">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="border" CornerRadius="8" BorderThickness="0">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                        <GradientStop Color="#42A5F5" Offset="0.0"/>
                                                                        <GradientStop Color="#1E88E5" Offset="1.0"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                                <Grid>
                                                                    <Border CornerRadius="8,8,0,0" Height="15" VerticalAlignment="Top" Opacity="0.2" Background="White" Margin="1,1,1,0"/>
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,5"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#64B5F6"/>
                                                                </Trigger>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=lstGroupSelection, Path=HasItems}" Value="False">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>

                                    <Popup IsOpen="{Binding ElementName=btnGroupMenu, Path=IsChecked}" StaysOpen="False" PlacementTarget="{Binding ElementName=btnGroupMenu}" Placement="Bottom" AllowsTransparency="True">
                                        <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="5" MinWidth="150" MaxHeight="200">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.4"/>
                                            </Border.Effect>
                                            <ScrollViewer>
                                                <ListBox x:Name="lstGroupSelection" BorderThickness="0" Background="Transparent">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding GroupName}" IsChecked="{Binding IsSelected}" 
                                                                      Foreground="{DynamicResource TextPrimary}" Margin="2"
                                                                      Click="GroupCheckBox_Click"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>

                                    <Button Grid.Column="1" Content="Filtrele" Width="60" Height="30" Margin="2,0,2,0" Click="BtnFilterGroups_Click" Style="{DynamicResource OrangeGlassButton}" ToolTip="Seçili grupları listele."/>
                                    <Button Grid.Column="2" Content="Sil" Width="40" Height="30" Click="BtnDeleteGroup_Click" Style="{DynamicResource RedGlassButton}" ToolTip="Seçili grupları sil."/>
                                </Grid>

                                <Button Content="LİSTEYİ TEMİZLE" Click="BtnClearDb_Click" Style="{DynamicResource RedGlassButton}" Margin="0,5,0,10" Height="25"/>
                            </StackPanel>

                            <DataGrid x:Name="dgRecipients" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended" 
                                      SelectionChanged="DgRecipients_SelectionChanged"
                                      Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" 
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      RowBackground="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}">

                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Seçili Kişiyi Sil" Click="BtnDeletePerson_Click">
                                            <MenuItem.Icon>
                                                <TextBlock Text="❌"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{DynamicResource AppBackground}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                        <Setter Property="Padding" Value="5"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ad" Binding="{Binding Ad}" Width="*"/>
                                    <DataGridTextColumn Header="Soyad" Binding="{Binding Soyad}" Width="*"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                                    <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="10" Padding="15" BorderThickness="0">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="5" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,5">
                                <Button Content="SEÇ &lt;+" DockPanel.Dock="Right" Width="70" Click="BtnAddTo_Click" Style="{DynamicResource BaseGlassButton}"/>
                                <TextBlock Text="Kime:" Width="65" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBox x:Name="txtTo" Height="30" Padding="5" VerticalContentAlignment="Center"/>
                            </DockPanel>

                            <DockPanel Grid.Row="1" Margin="0,0,0,5">
                                <Button Content="SEÇ &lt;+" DockPanel.Dock="Right" Width="70" Click="BtnAddCc_Click" Style="{DynamicResource BaseGlassButton}"/>
                                <TextBlock Text="CC:" Width="65" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBox x:Name="txtCc" Height="30" Padding="5" VerticalContentAlignment="Center"/>
                            </DockPanel>

                            <DockPanel Grid.Row="2" Margin="0,0,0,5">
                                <TextBlock Text="Konu:" Width="65" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBox x:Name="txtSubject" Height="30" Padding="5" VerticalContentAlignment="Center"/>
                            </DockPanel>

                            <DockPanel Grid.Row="3" Margin="0,0,0,5">
                                <TextBlock Text="Spoofing :" Width="65" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#E53935" ToolTip="Mail kimden gidiyor görünsün? (Spoofing)"/>
                                <TextBox x:Name="txtSpoofMail" Height="30" Padding="5" VerticalContentAlignment="Center" 
                                         ToolTip="Boş bırakırsan kendi mailin görünür. Farklı bir adres yazarsan o görünür."
                                         Text="{Binding Source={x:Static local:GlobalSettings.UserMail}, Mode=OneWay}"/>
                            </DockPanel>

                            <DockPanel Grid.Row="4" Margin="65,5,0,5">
                                <TextBlock Text="Otomatik Veri:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextSecondary}"/>
                                <Button Content="İmlece Ekle" DockPanel.Dock="Right" Width="100" Margin="5,0,0,0" Click="BtnInsertVariable_Click" Style="{DynamicResource BaseGlassButton}"/>
                                <ComboBox x:Name="cmbVariables" Height="30"/>
                            </DockPanel>

                            <DockPanel Grid.Row="5" Margin="65,5,0,5">
                                <TextBlock Text="Hazır Mesaj:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextSecondary}"/>
                                <Button Content="Kaydet" DockPanel.Dock="Right" Width="60" Margin="5,0,0,0" Click="BtnSaveTemplate_Click" Style="{DynamicResource GreenGlassButton}"/>
                                <Button Content="Sil" DockPanel.Dock="Right" Width="40" Click="BtnDeleteTemplate_Click" Style="{DynamicResource RedGlassButton}"/>
                                <ComboBox x:Name="cmbTemplates" SelectionChanged="CmbTemplates_SelectionChanged" DisplayMemberPath="Title" Height="30"/>
                            </DockPanel>

                            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
                                <Button Content="🔗 Link Ekle" Width="90" Height="25" Margin="0,0,5,0" Click="BtnAddLink_Click" Style="{DynamicResource BaseGlassButton}" FontSize="11"/>
                                <Button Content="✒️ İmza Ayarla" Width="90" Height="25" Margin="0,0,5,0" Click="BtnSetSignature_Click" Style="{DynamicResource OrangeGlassButton}" FontSize="11"/>
                                <CheckBox x:Name="chkUseSignature" Content="İmza Ekle" VerticalAlignment="Center" IsChecked="True" Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>

                            <TextBox x:Name="txtBody" Grid.Row="7" AcceptsReturn="True" TextWrapping="Wrap" 
                                     VerticalScrollBarVisibility="Auto" Margin="0,5" Padding="10"
                                     VerticalContentAlignment="Top" FontSize="14"
                                     AllowDrop="True" PreviewDragOver="TextBox_PreviewDragOver" Drop="TextBox_Drop"
                                     BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource AppBackground}" 
                                     Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}"/>

                            <Button Content="TASLAĞI KUYRUĞA EKLE" Grid.Row="8" Height="45" Margin="0,5,0,0" Click="BtnAddToQueue_Click" Style="{DynamicResource OrangeGlassButton}"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Background="{DynamicResource CardBackground}" CornerRadius="10" Margin="15,5,15,15" Padding="10" BorderThickness="0">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="5" ShadowDepth="-2" Opacity="0.1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="lblQueueCount" Text="Bekleyen: 0" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                            <TextBlock Text="Listeyi Süz:" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="2,0,0,2"/>
                            <ComboBox x:Name="cmbQueueFilter" SelectionChanged="CmbQueueFilter_SelectionChanged" Height="30" Margin="0,0,0,5">
                                <ComboBoxItem Content="Tümü" IsSelected="True"/>
                                <ComboBoxItem Content="Bekliyor"/>
                                <ComboBoxItem Content="Gönderiliyor..."/>
                                <ComboBoxItem Content="Gönderildi"/>
                                <ComboBoxItem Content="HATA"/>
                            </ComboBox>

                            <UniformGrid Columns="2">
                                <Button x:Name="btnSend" Content="BAŞLAT ▶" Height="35" Click="BtnSendQueue_Click" Style="{DynamicResource GreenGlassButton}" Margin="0,0,3,0"/>
                                <Button Content="TEMİZLE 🗑" Height="35" Click="BtnClearQueue_Click" Style="{DynamicResource RedGlassButton}" Margin="3,0,0,0"/>
                            </UniformGrid>
                        </StackPanel>

                        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ListBox x:Name="lstQueue" BorderThickness="0" Background="Transparent" 
                                     MouseDoubleClick="LstQueue_MouseDoubleClick">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="200" Height="100" CornerRadius="8" Background="{DynamicResource AppBackground}" Margin="5" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <TextBlock Text="{Binding To}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" Margin="0,0,25,0"/>
                                                    <Button Content="X" HorizontalAlignment="Right" Width="20" Height="20" Click="BtnRemoveSingleItem_Click" Style="{DynamicResource RedGlassButton}" FontSize="10" Padding="0"/>
                                                </Grid>

                                                <TextBlock Grid.Row="1" Text="{Binding Subject}" FontSize="11" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,5"/>

                                                <TextBlock Grid.Row="2" Text="{Binding Status}" 
                                                           FontSize="12" FontWeight="SemiBold" 
                                                           HorizontalAlignment="Right"
                                                           Cursor="Hand"
                                                           MouseLeftButtonDown="TxtStatus_MouseLeftButtonDown"
                                                           ToolTip="Hata detayını görmek için tıklayın">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#039BE5"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="HATA">
                                                                    <Setter Property="Foreground" Value="Red"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Gönderildi">
                                                                    <Setter Property="Foreground" Value="#43A047"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>