<Window x:Class="MAB_Mailer.TemplateNameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Şablon Adı" Height="200" Width="350"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" Icon="/icon.png">

    <Border Background="{DynamicResource CardBackground}" CornerRadius="15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="15" Opacity="0.4"/>
        </Border.Effect>
        <Grid Margin="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Şablon Adı Giriniz:" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>

                <TextBox x:Name="txtTemplateName" Height="35" VerticalContentAlignment="Center" Padding="5" 
                         Background="{DynamicResource InputBackground}" Foreground="{DynamicResource InputForeground}"
                         BorderBrush="{DynamicResource InputBorder}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="İptal" Width="80" Height="30" Click="BtnCancel_Click" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="5" Background="#EF5350">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Kaydet" Width="80" Height="30" Click="BtnSave_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="5" Background="#66BB6A">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>