<Window x:Class="MAB_Mailer.CustomAlert"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uyarı" Height="200" Width="400"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" Background="Transparent"
        WindowStyle="None" ResizeMode="NoResize"
        Topmost="True" Icon="/icon.png">
    <Border Background="{DynamicResource CardBackground}" CornerRadius="15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtTitle" Text="Başlık" FontSize="18" FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>

            <TextBlock x:Name="txtMessage" Grid.Row="1" Text="Buraya uyarı mesajı gelecek..." 
                       FontSize="14" Foreground="{DynamicResource TextSecondary}" 
                       TextWrapping="Wrap" VerticalAlignment="Center"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">

                <Button x:Name="btnOk" Content="Tamam" Width="100" Height="35" Click="BtnOk_Click" 
                        Visibility="Collapsed" Style="{StaticResource BaseGlassButton}"/>

                <StackPanel x:Name="pnlYesNo" Orientation="Horizontal" Visibility="Collapsed">
                    <Button Content="Vazgeç" Width="80" Height="35" Margin="0,0,10,0" Click="BtnCancel_Click" 
                            Style="{StaticResource RedGlassButton}"/>
                    <Button Content="Onayla" Width="80" Height="35" Click="BtnOk_Click" 
                            Style="{StaticResource GreenGlassButton}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>